#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PID_FILE="$DIR/.modelmeter.pid"
LOG_FILE="$DIR/.modelmeter.log"

API_PORT="${PORT:-3456}"
VITE_PORT="${VITE_PORT:-5173}"

usage() {
  echo ""
  echo "ModelMeter Dashboard — Usage:"
  echo ""
  echo "  ./modelmeter start        Start server in background"
  echo "  ./modelmeter stop         Stop server"
  echo "  ./modelmeter status       Show server status"
  echo "  ./modelmeter restart      Restart server"
  echo "  ./modelmeter logs         Show recent logs (tail -f)"
  echo "  ./modelmeter foreground   Run in foreground (Ctrl+C to stop)"
  echo ""
}

is_running() {
  if [ ! -f "$PID_FILE" ]; then return 1; fi
  local api_pid vite_pid
  api_pid=$(sed -n '1p' "$PID_FILE")
  vite_pid=$(sed -n '2p' "$PID_FILE")
  kill -0 "$api_pid" 2>/dev/null && kill -0 "$vite_pid" 2>/dev/null
}

cmd_start() {
  if is_running; then
    echo "Already running. Use './modelmeter status' to check or './modelmeter restart'."
    exit 0
  fi

  echo "Starting ModelMeter Dashboard..."

  # Start API server in background
  PORT="$API_PORT" node "$DIR/src/server.js" >> "$LOG_FILE" 2>&1 &
  local api_pid=$!

  # Start Vite dev server in background
  npx vite --host >> "$LOG_FILE" 2>&1 &
  local vite_pid=$!

  # Save PIDs
  echo "$api_pid" > "$PID_FILE"
  echo "$vite_pid" >> "$PID_FILE"

  # Wait for ports to be ready
  echo -n "Waiting for API server (port $API_PORT)"
  for i in $(seq 1 30); do
    if curl -s "http://localhost:$API_PORT/api/providers" > /dev/null 2>&1; then
      echo " ready."
      break
    fi
    sleep 0.5
    echo -n "."
  done

  echo -n "Waiting for Vite server (port $VITE_PORT)"
  for i in $(seq 1 30); do
    if curl -s "http://localhost:$VITE_PORT" > /dev/null 2>&1; then
      echo " ready."
      break
    fi
    sleep 0.5
    echo -n "."
  done

  echo ""
  echo "Dashboard running:"
  echo "  Frontend: http://localhost:$VITE_PORT"
  echo "  API:      http://localhost:$API_PORT"
  echo "  Logs:     $LOG_FILE"
  echo "  Stop:     ./modelmeter stop"
}

cmd_stop() {
  if ! is_running; then
    echo "Not running."
    rm -f "$PID_FILE"
    exit 0
  fi

  local api_pid vite_pid
  api_pid=$(sed -n '1p' "$PID_FILE")
  vite_pid=$(sed -n '2p' "$PID_FILE")

  echo "Stopping ModelMeter Dashboard..."
  kill "$api_pid" 2>/dev/null || true
  kill "$vite_pid" 2>/dev/null || true
  rm -f "$PID_FILE"
  echo "Stopped."
}

cmd_status() {
  if is_running; then
    local api_pid vite_pid
    api_pid=$(sed -n '1p' "$PID_FILE")
    vite_pid=$(sed -n '2p' "$PID_FILE")
    echo "Running (API: $api_pid, Vite: $vite_pid)"
    echo "  Frontend: http://localhost:$VITE_PORT"
    echo "  API:      http://localhost:$API_PORT"
  else
    echo "Not running."
  fi
}

cmd_restart() {
  cmd_stop
  sleep 1
  cmd_start
}

cmd_logs() {
  if [ ! -f "$LOG_FILE" ]; then
    echo "No logs yet."
    exit 0
  fi
  tail -f "$LOG_FILE"
}

cmd_foreground() {
  echo "Running in foreground. Press Ctrl+C to stop."
  exec npm start --prefix "$DIR"
}

case "${1:-}" in
  start)        cmd_start ;;
  stop)         cmd_stop ;;
  status)       cmd_status ;;
  restart)      cmd_restart ;;
  logs)         cmd_logs ;;
  foreground)   cmd_foreground ;;
  *)            usage ;;
esac

{
  "name": "modelmeter",
  "version": "1.0.0",
  "description": "Multi-provider AI model usage and cost dashboard",
  "type": "module",
  "scripts": {
    "start": "concurrently -n api,web -c blue,green \"node src/server.js\" \"vite\"",
    "dev": "npm start",
    "build": "vite build",
    "test": "node --test tests/**/*.test.js",
    "stop": "./modelmeter stop",
    "status": "./modelmeter status",
    "restart": "./modelmeter restart",
    "logs": "./modelmeter logs",
    "start:bg": "./modelmeter start"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chart.js": "^4.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0"
  }
}
